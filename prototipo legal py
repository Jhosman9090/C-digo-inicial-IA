# Preguntas relacionadas para la Teoría de la Pregunta Infinita
preguntas_relacionadas = [
    "¿Qué delitos son considerados federales en México?",
    "¿Cómo se aplica la proporcionalidad en casos graves?",
    "¿Qué papel juega la presunción de inocencia en el proceso penal?",
    "¿Qué diferencias existen entre el Código Penal Federal y los Estatales?",
    "¿Cómo ha evolucionado la noción de humanidad en las penas mexicanas?"
]

def generar_preguntas():
    print("\nPreguntas relacionadas (Teoría de la Pregunta Infinita):")
    seleccionadas = random.sample(preguntas_relacionadas, 3)
    for p in seleccionadas:
        print(f"- {p}")

if __name__ == "__main__":
    print("=== Resumen Ley Penal de México ===\n")
    print(json.dumps(resumen_ley_penal, indent=4, ensure_ascii=False))
    generar_preguntas()
