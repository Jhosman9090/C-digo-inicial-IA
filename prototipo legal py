                "Principios: legalidad, proporcionalidad, humanidad, presunción de inocencia (✅)",
                "Ámbitos de validez: personal, territorial, temporal (✅)",
                "Elementos del delito: sujeto activo, sujeto pasivo, conducta, tipicidad, antijuridicidad, culpabilidad (✅)"
            ]
        },
        "TB": {
            "name": "Teoría de Burbujas aplicada",
            "rules": [
                "Burbuja Verificada: normas constitucionales y códigos penales (✅)",
                "Burbuja Complementaria: hipótesis sobre evolución futura del derecho penal (❓)",
                "Conexiones: cada burbuja puede generar preguntas sobre justicia, derechos humanos y reformas legales (❓)"
            ]
        }
    },
    "interaction": {
        "style": "human_like",
        "features": [
